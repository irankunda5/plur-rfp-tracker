# PLUR RFP Tracker - Environment Variables
# Copy to .env and fill in values as needed.
# All variables are optional - the tracker runs without them.

# Slack alerts (Phase 6)
# RFP_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# RFP_SLACK_MIN_TIER=2

# SAM.gov US federal procurement (disabled without key)
# SAM_GOV_API_KEY=

# Email digest (Phase 6)
# RFP_SMTP_HOST=
# RFP_SMTP_PORT=587
# RFP_SMTP_USER=
# RFP_SMTP_PASSWORD=
# RFP_DIGEST_RECIPIENTS=

# HubSpot Signals integration
# HUBSPOT_API_KEY=
# HUBSPOT_OBJECT_TYPE_ID=2-229341360
